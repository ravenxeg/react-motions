{
	"name": "@ravenxeg/react-motions",
	"version": "1.0.0",
	"packageManager": "pnpm@11.3.0",
	"description": "Predefined premium animations for Next.js and React powered by motion/react",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"sideEffects": false,
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"clean": "rimraf dist",
		"typecheck": "tsc --noEmit",
		"prepare": "tsdown"
	},
	"keywords": [
		"react",
		"nextjs",
		"motion",
		"framer-motion",
		"motion-react",
		"animations",
		"components"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ravenxeg/react-motions.git"
	},
	"homepage": "https://github.com/ravenxeg/react-motions#readme",
	"bugs": {
		"url": "https://github.com/ravenxeg/react-motions/issues"
	},
	"author": "ravenxeg",
	"license": "Apache-2.0",
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"motion": "^11.0.0 || ^12.0.0",
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"motion": "^11.11.17",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"rimraf": "^5.0.7",
		"tsdown": "^0.22.1",
		"typescript": "^5.4.5"
	}
}
